# Unity MCP server configuration.
#
# Copy this file to ".env" (which is gitignored) and fill in any values you
# need. Every variable is optional — unset values fall back to the defaults
# shown here, and the AI asset tools simply stay disabled until configured.

# --- Unity bridge connection ---
UNITY_MCP_HOST=127.0.0.1
UNITY_MCP_PORT=6400
UNITY_MCP_CONNECT_TIMEOUT=5
UNITY_MCP_REQUEST_TIMEOUT=30
UNITY_MCP_RECONNECT_TIMEOUT=60
UNITY_MCP_RECONNECT_INTERVAL=0.5

# --- Optional: AI texture generation (image model) ---
# Azure OpenAI resource endpoint, OR a full OpenAI-compatible images URL.
UNITY_MCP_IMAGE_ENDPOINT=
# API key for the image endpoint. (secret — keep it out of git)
UNITY_MCP_IMAGE_API_KEY=
# Azure deployment name. Leave blank for OpenAI-compatible servers.
UNITY_MCP_IMAGE_DEPLOYMENT=
UNITY_MCP_IMAGE_API_VERSION=2024-10-21

# --- Optional: AI audio generation (ElevenLabs) ---
# ElevenLabs API key. (secret — keep it out of git)
UNITY_MCP_ELEVENLABS_API_KEY=
UNITY_MCP_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
UNITY_MCP_ELEVENLABS_MODEL=eleven_multilingual_v2
UNITY_MCP_ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# --- Optional: generated asset locations & outbound HTTP timeout ---
UNITY_MCP_TEXTURE_FOLDER=Assets/MCP/Textures
UNITY_MCP_AUDIO_FOLDER=Assets/MCP/Audio
UNITY_MCP_HTTP_TIMEOUT=120
